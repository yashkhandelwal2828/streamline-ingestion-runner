NODE_ENV=production

# GitHub Actions secrets (Settings → Secrets and variables → Actions)
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require&connection_limit=2
TMDB_API_KEY=replace-with-tmdb-key
OMDB_API_KEY=replace-with-omdb-key

# Worker: process queue only — never register node-cron schedules in CI
RUN_CRON_SCHEDULER=false

# TMDB rate limiting
TMDB_REQUESTS_PER_SECOND=8
TMDB_MAX_429_BACKOFF_SECONDS=300

# Queue management
INGESTION_QUEUE_HIGH_WATERMARK=10000
INGESTION_QUEUE_REFILL_TARGET=800
INGESTION_DAILY_TARGET=500
INGESTION_ALLOWED_JOB_TYPES=
INGESTION_POLL_INTERVAL_MS=5000
INGESTION_MAX_JOBS_PER_TICK=5
INGESTION_STALE_RECOVERY_MINUTES=15
INGESTION_STALE_RECOVERY_INTERVAL_MS=60000

# Hindi-first catalog growth
INGESTION_MIN_RELEASE_YEAR=2010
INGESTION_LANGUAGE_MODE=weighted
INGESTION_LANGUAGE_WEIGHTS=hi:100,en:20,ta:15,te:15,ml:10
INGESTION_FALLBACK_TO_GLOBAL=true
INGESTION_LANGUAGE_DEEP_SCAN_MAX_PAGES=100
INGESTION_LANGUAGE_BROAD_SCAN_MAX_PAGES=250

# OMDb enrichment (independent lane)
INGESTION_OMDB_DAILY_LIMIT=200
INGESTION_OMDB_RETRY_RESERVE=50
INGESTION_OMDB_MAX_FETCH_BACKLOG=100
INGESTION_OMDB_MIN_CATALOG_PROGRESS_RATIO=0.8

# Cleanup retention
INGESTION_SNAPSHOT_RETENTION_DAYS=1
INGESTION_JOB_HISTORY_RETENTION_DAYS=7
INGESTION_STORE_OMDB_SNAPSHOTS=false
INGESTION_DELETE_TMDB_SNAPSHOT_AFTER_NORMALIZE=true

# Delta refresh tuning
INGESTION_DELTA_PAGES_TO_SCAN=2
INGESTION_DELTA_TARGET_COUNT=50
INGESTION_DELTA_WINDOW_HOURS=48
